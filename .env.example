# Camera credentials — VIDEO_SOURCE is built automatically from these.
# Set VIDEO_SOURCE explicitly only if you need a non-standard URL.
CAMERA_IP=192.168.1.xxx
RTSP_USER=admin
RTSP_PASSWORD=changeme
# VIDEO_SOURCE=rtsp://admin:changeme@192.168.1.xxx:554/stream1

# Data directory (default /data inside Docker; set for local runs)
DATA_DIR=/home/youruser/backyardBirdwatch/data

# MQTT
MQTT_USER=birdfeeder
MQTT_PASSWORD=changeme

# Species classifier backend: efficientnet | tfhub | bioclip | nabirds
CLASSIFIER_BACKEND=efficientnet
EFFICIENTNET_MODEL_PATH=/home/youruser/backyardBirdwatch/data/models/feeder_birds.pt

# Detection thresholds
MIN_CONFIDENCE_LOG=0.3
MIN_CONFIDENCE_NOTIFY=0.7
DETECTION_COOLDOWN_SEC=10.0
